{
  "id": "flowdsl/email-fetcher",
  "name": "Email Fetcher",
  "version": "1.0.0",
  "summary": "Polls an IMAP or POP3 mailbox and emits one event per received email.",
  "description": "# Email Fetcher\n\nConnects to an IMAP or POP3 mailbox on a configurable interval and emits a `EmailReceived` event for each new message. Supports SSL/TLS connections and configurable folder selection.\n\n## Use cases\n- Trigger flows from incoming support emails\n- Process invoice emails automatically\n- Monitor alert inboxes\n\n## Notes\n- Requires a valid IMAP/POP3 host and credentials\n- Marks messages as read after fetching to avoid duplicate processing\n- `body` contains the plain-text part of the email; HTML parts are stripped",
  "kind": "source",
  "language": "python",
  "author": {
    "name": "FlowDSL Team",
    "url": "https://flowdsl.com",
    "email": "nodes@flowdsl.com"
  },
  "license": "Apache-2.0",
  "repoUrl": "https://github.com/flowdsl/flowdsl-python",
  "docsUrl": "https://flowdsl.com/nodes/email-fetcher",
  "icon": "📧",
  "color": "#4F46E5",
  "tags": [
    "email",
    "imap",
    "pop3",
    "source",
    "polling"
  ],
  "runtime": {
    "handler": "flowdsl.nodes.email.EmailFetcherNode",
    "supports": ["proc", "grpc", "http"],
    "grpc": {
      "port": 50052
    }
  },
  "inputs": [],
  "outputs": [
    {
      "name": "EmailReceived",
      "description": "Emitted once for each new email retrieved from the mailbox.",
      "schema": {
        "type": "object",
        "required": [
          "messageId",
          "from",
          "to",
          "subject",
          "receivedAt"
        ],
        "properties": {
          "messageId": {
            "type": "string",
            "description": "Unique message-ID header value."
          },
          "from": {
            "type": "string",
            "description": "Sender address (RFC 5322 format)."
          },
          "to": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Recipient addresses."
          },
          "subject": {
            "type": "string",
            "description": "Email subject line."
          },
          "body": {
            "type": "string",
            "description": "Plain-text body of the email."
          },
          "receivedAt": {
            "type": "string",
            "format": "date-time",
            "description": "Timestamp when the email was received by the mail server."
          }
        }
      }
    }
  ],
  "settingsSchema": {
    "type": "object",
    "required": [
      "host",
      "username",
      "password"
    ],
    "properties": {
      "host": {
        "type": "string",
        "title": "IMAP/POP3 Host",
        "description": "Hostname or IP address of the mail server.",
        "x-ui": {
          "placeholder": "mail.example.com",
          "order": 1,
          "group": "Connection"
        }
      },
      "port": {
        "type": "number",
        "title": "Port",
        "description": "Server port. Defaults to 993 for IMAP over TLS.",
        "default": 993,
        "x-ui": {
          "order": 2,
          "group": "Connection"
        }
      },
      "username": {
        "type": "string",
        "title": "Username",
        "description": "Login username or email address.",
        "x-ui": {
          "placeholder": "user@example.com",
          "order": 3,
          "group": "Connection"
        }
      },
      "password": {
        "type": "string",
        "title": "Password",
        "description": "Login password. Stored securely in the credential store.",
        "format": "password",
        "x-ui": {
          "order": 4,
          "group": "Connection",
          "secret": true
        }
      },
      "protocol": {
        "type": "string",
        "title": "Protocol",
        "description": "Mail protocol to use.",
        "enum": [
          "imap",
          "pop3"
        ],
        "default": "imap",
        "x-ui": {
          "order": 5,
          "group": "Connection"
        }
      },
      "folder": {
        "type": "string",
        "title": "Folder",
        "description": "Mailbox folder to poll. IMAP only.",
        "default": "INBOX",
        "x-ui": {
          "order": 6,
          "group": "Polling"
        }
      },
      "pollIntervalSec": {
        "type": "number",
        "title": "Poll Interval (seconds)",
        "description": "How often to check for new messages.",
        "default": 30,
        "minimum": 5,
        "x-ui": {
          "order": 7,
          "group": "Polling"
        }
      }
    }
  },
  "minRuntimeVersion": "1.0.0",
  "published": true,
  "publishedAt": "2026-01-15T10:00:00Z",
  "x-studio": {
    "lucideIcon": "Mail",
    "color": "#3B82F6",
    "packetPreview": {
      "type": "EmailMessage",
      "fields": [
        {
          "name": "from",
          "type": "string",
          "example": "\"alice@example.com\""
        },
        {
          "name": "subject",
          "type": "string",
          "example": "\"Order #1029 shipped\""
        },
        {
          "name": "body",
          "type": "string",
          "example": "\"Your order has...\""
        },
        {
          "name": "date",
          "type": "string",
          "example": "\"2024-01-15T09:00:00Z\""
        },
        {
          "name": "messageId",
          "type": "string",
          "example": "\"<abc@mail.example.com>\""
        }
      ]
    }
  }
}
