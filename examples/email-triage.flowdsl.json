{
  "flowdsl": "1.0.0",
  "info": {
    "title": "Smart Email Triage",
    "version": "1.0.0",
    "description": "LLM classifies incoming emails and routes them to auto-reply or Slack notification based on priority."
  },
  "flows": {
    "email_triage": {
      "summary": "Smart email triage",
      "description": "Fetches new emails, classifies intent with LLM, then routes to auto-reply or team Slack alert.",
      "nodes": {
        "email_fetcher": {
          "$ref": "#/components/nodes/EmailFetcherNode"
        },
        "llm_classifier": {
          "$ref": "#/components/nodes/LlmClassifierNode"
        },
        "intent_router": {
          "$ref": "#/components/nodes/IntentRouterNode"
        },
        "email_sender": {
          "$ref": "#/components/nodes/EmailSenderNode"
        },
        "slack_notifier": {
          "$ref": "#/components/nodes/SlackNotifierNode"
        }
      },
      "edges": [
        {
          "from": "email_fetcher",
          "to": "llm_classifier",
          "packet": "#/components/packets/IncomingEmail",
          "description": "Send raw email to LLM for classification",
          "delivery": {
            "mode": "direct"
          }
        },
        {
          "from": "llm_classifier",
          "to": "intent_router",
          "packet": "#/components/packets/ClassificationResult",
          "description": "Pass classification result to router",
          "delivery": {
            "mode": "direct"
          }
        },
        {
          "from": "intent_router",
          "to": "email_sender",
          "packet": "#/components/packets/EmailReply",
          "when": "output.category == 'support' || output.category == 'inquiry'",
          "description": "Auto-reply to support and inquiry emails",
          "delivery": {
            "mode": "durableQueue",
            "store": "mongo",
            "retryPolicy": {
              "$ref": "#/components/policies/emailRetry"
            }
          }
        },
        {
          "from": "intent_router",
          "to": "slack_notifier",
          "packet": "#/components/packets/ClassificationResult",
          "when": "output.priority == 'high'",
          "description": "Alert team on Slack for high-priority emails",
          "delivery": {
            "mode": "ephemeralQueue",
            "backend": "redis"
          }
        }
      ]
    }
  },
  "components": {
    "policies": {
      "emailRetry": {
        "maxAttempts": 5,
        "initialDelayMs": 1000,
        "backoff": "exponential",
        "maxDelayMs": 60000,
        "deadLetterQueue": true
      }
    },
    "events": {
      "EmailReceived": {
        "summary": "A new email has been fetched from the inbox",
        "version": "1.0.0",
        "entityType": "email",
        "action": "received",
        "tags": ["email", "inbound"],
        "payload": {
          "$ref": "#/components/packets/IncomingEmail"
        }
      },
      "EmailClassified": {
        "summary": "The LLM has classified an email intent and priority",
        "version": "1.0.0",
        "entityType": "email",
        "action": "classified",
        "tags": ["email", "classification", "llm"],
        "payload": {
          "$ref": "#/components/packets/ClassificationResult"
        }
      }
    },
    "packets": {
      "IncomingEmail": {
        "description": "Raw email fetched from the mailbox",
        "properties": {
          "from": {
            "type": "string",
            "description": "Sender address"
          },
          "subject": {
            "type": "string"
          },
          "body": {
            "type": "string",
            "description": "Plain-text email body"
          },
          "received_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "from",
          "subject",
          "body",
          "received_at"
        ],
        "type": "object"
      },
      "ClassificationResult": {
        "description": "LLM classification of an incoming email",
        "properties": {
          "category": {
            "type": "string",
            "description": "support | inquiry | spam | newsletter"
          },
          "priority": {
            "type": "string",
            "description": "low | medium | high"
          },
          "summary": {
            "type": "string",
            "description": "One-sentence summary generated by the LLM"
          },
          "from": {
            "type": "string"
          }
        },
        "required": [
          "category",
          "priority",
          "summary"
        ],
        "type": "object"
      },
      "EmailReply": {
        "description": "Auto-generated reply to be sent back to the sender",
        "properties": {
          "to": {
            "type": "string"
          },
          "subject": {
            "type": "string"
          },
          "body": {
            "type": "string"
          }
        },
        "required": [
          "to",
          "subject",
          "body"
        ],
        "type": "object"
      }
    },
    "nodes": {
      "EmailFetcherNode": {
        "operationId": "fetch_emails",
        "title": "Email Fetcher",
        "summary": "Poll the inbox for new unread emails via IMAP",
        "kind": "source",
        "x-ui": {
          "icon": "Mail",
          "color": "#3B82F6",
          "position": {
            "x": 300,
            "y": 80
          },
          "registryId": "email-fetcher"
        }
      },
      "LlmClassifierNode": {
        "operationId": "classify_email_intent",
        "title": "LLM Classifier",
        "summary": "Classify email intent and priority using an LLM prompt",
        "kind": "llm",
        "execution": {
          "timeoutMs": 15000,
          "concurrency": 5,
          "maxRetries": 2
        },
        "x-ui": {
          "icon": "Bot",
          "color": "#8B5CF6",
          "position": {
            "x": 300,
            "y": 240
          },
          "registryId": "llm-analyzer"
        }
      },
      "IntentRouterNode": {
        "operationId": "route_by_intent",
        "title": "Intent Router",
        "summary": "Route classified emails to the appropriate handler",
        "kind": "router",
        "x-ui": {
          "icon": "Filter",
          "color": "#F59E0B",
          "position": {
            "x": 300,
            "y": 400
          },
          "registryId": "filter-node"
        }
      },
      "EmailSenderNode": {
        "operationId": "send_auto_reply",
        "title": "Email Sender",
        "summary": "Send a templated auto-reply acknowledging the email",
        "kind": "terminal",
        "idempotency": {
          "enabled": true,
          "keyExpression": "input.payload.from + ':' + input.payload.subject",
          "ttlSeconds": 7200,
          "store": "redis"
        },
        "x-ui": {
          "icon": "MailCheck",
          "color": "#EF4444",
          "position": {
            "x": 140,
            "y": 560
          },
          "registryId": "email-sender"
        }
      },
      "SlackNotifierNode": {
        "operationId": "notify_team_slack",
        "title": "Slack Notifier",
        "summary": "Post high-priority email summary to the team Slack channel",
        "kind": "action",
        "x-ui": {
          "icon": "MessageSquare",
          "color": "#F97316",
          "position": {
            "x": 460,
            "y": 560
          },
          "registryId": "slack-notifier"
        }
      }
    }
  }
}