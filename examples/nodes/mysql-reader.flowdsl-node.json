{
  "id": "flowdsl/mysql-reader",
  "name": "MySQL Reader",
  "version": "1.0.0",
  "summary": "Queries rows from a MySQL table and emits them as packets.",
  "description": "# MySQL Reader\n\nExecutes a configurable SELECT query against a MySQL database. Supports parameterized queries, pagination via LIMIT/OFFSET or cursor, and scheduled polling. Each row is emitted as an individual packet.\n\n## Use cases\n- Poll for new or changed rows\n- Export data from MySQL into FlowDSL pipelines\n- Incremental reads via cursor-based pagination\n\n## Notes\n- Uses ? placeholders for parameterized queries\n- Cursor field enables incremental reads across polls\n- pollIntervalMs = 0 means run once",
  "kind": "source",
  "language": "go",
  "author": {
    "name": "FlowDSL Team",
    "url": "https://flowdsl.com",
    "email": "nodes@flowdsl.com"
  },
  "license": "Apache-2.0",
  "repoUrl": "https://github.com/flowdsl/flowdsl-go",
  "docsUrl": "https://flowdsl.com/nodes/mysql-reader",
  "icon": "🐬",
  "color": "#00758F",
  "tags": [
    "mysql",
    "database",
    "sql",
    "source",
    "reader"
  ],
  "runtime": {
    "handler": "github.com/flowdsl/flowdsl-go/nodes/mysql.ReaderNode",
    "invocation": "inProcess"
  },
  "inputs": [],
  "outputs": [
    {
      "name": "Row",
      "description": "Emitted for each row returned by the query.",
      "schema": {
        "type": "object",
        "description": "Dynamic schema matching the query result columns."
      }
    }
  ],
  "settingsSchema": {
    "type": "object",
    "required": [
      "connectionUri",
      "query"
    ],
    "properties": {
      "connectionUri": {
        "type": "string",
        "title": "Connection URI",
        "description": "MySQL connection string.",
        "format": "password",
        "x-ui": {
          "placeholder": "user:pass@tcp(localhost:3306)/dbname",
          "order": 1,
          "group": "Connection",
          "secret": true
        }
      },
      "query": {
        "type": "string",
        "title": "SQL Query",
        "description": "SELECT query to execute.",
        "x-ui": {
          "placeholder": "SELECT * FROM users WHERE active = 1",
          "order": 2,
          "group": "Query"
        }
      },
      "params": {
        "type": "array",
        "title": "Query Parameters",
        "description": "Positional query parameters (? placeholders).",
        "x-ui": {
          "order": 3,
          "group": "Query"
        }
      },
      "batchSize": {
        "type": "number",
        "title": "Batch Size",
        "description": "Rows to fetch per batch.",
        "default": 100,
        "minimum": 1,
        "maximum": 10000,
        "x-ui": {
          "order": 4,
          "group": "Pagination"
        }
      },
      "cursorField": {
        "type": "string",
        "title": "Cursor Field",
        "description": "Field for cursor-based pagination (incremental reads).",
        "x-ui": {
          "placeholder": "updated_at",
          "order": 5,
          "group": "Pagination"
        }
      },
      "pollIntervalMs": {
        "type": "number",
        "title": "Poll Interval (ms)",
        "description": "Polling interval in ms (0 = run once).",
        "default": 0,
        "x-ui": {
          "order": 6,
          "group": "Scheduling"
        }
      }
    }
  },
  "minRuntimeVersion": "1.0.0",
  "published": true,
  "publishedAt": "2026-01-15T10:00:00Z",
  "x-studio": {
    "lucideIcon": "Table2",
    "color": "#3B82F6",
    "packetPreview": {
      "type": "MySQLRow",
      "fields": [
        {
          "name": "id",
          "type": "number",
          "example": "4821"
        },
        {
          "name": "email",
          "type": "string",
          "example": "\"alice@example.com\""
        },
        {
          "name": "status",
          "type": "string",
          "example": "\"active\""
        },
        {
          "name": "created_at",
          "type": "string",
          "example": "\"2024-01-10T08:00:00Z\""
        }
      ]
    }
  }
}
