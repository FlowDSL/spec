{
  "flowdsl": "1.0.0",
  "info": {
    "title": "Event-Driven AI Pipeline",
    "version": "1.0.0",
    "description": "Listens to events, analyzes content with an LLM, scores and routes to persistence, notifications, and alerts."
  },
  "flows": {
    "ai_event_pipeline": {
      "summary": "AI-powered event processing pipeline",
      "description": "An event source feeds incoming events to an LLM analyzer. The analyzer scores the content and produces a structured assessment. A router fans out based on score: high-risk items go to Slack + email, all results persist to MongoDB.",
      "entrypoints": ["event_source"],
      "nodes": {
        "event_source": {
          "$ref": "#/components/nodes/EventSourceNode"
        },
        "llm_analyzer": {
          "$ref": "#/components/nodes/LLMAnalyzerNode"
        },
        "score_router": {
          "$ref": "#/components/nodes/ScoreRouterNode"
        },
        "mongo_writer": {
          "$ref": "#/components/nodes/MongoWriterNode"
        },
        "slack_notifier": {
          "$ref": "#/components/nodes/SlackNotifierNode"
        },
        "email_alert": {
          "$ref": "#/components/nodes/EmailAlertNode"
        }
      },
      "edges": [
        {
          "from": "event_source",
          "to": "llm_analyzer",
          "packet": "#/components/packets/IncomingEvent",
          "description": "Stream events to the LLM for analysis",
          "delivery": { "mode": "ephemeral", "backend": "redis" }
        },
        {
          "from": "llm_analyzer",
          "to": "score_router",
          "packet": "#/components/packets/AnalysisResult",
          "description": "Route scored analysis results",
          "delivery": { "mode": "direct" }
        },
        {
          "from": "score_router",
          "to": "mongo_writer",
          "packet": "#/components/packets/AnalysisResult",
          "description": "Persist all analysis results to MongoDB",
          "delivery": {
            "mode": "durable",
            "store": "mongo",
            "retryPolicy": { "$ref": "#/components/policies/writeRetry" }
          }
        },
        {
          "from": "score_router",
          "to": "slack_notifier",
          "packet": "#/components/packets/AlertNotification",
          "when": "output.riskScore >= 0.7",
          "description": "Alert ops channel for high-risk events",
          "delivery": { "mode": "ephemeral", "backend": "redis" }
        },
        {
          "from": "score_router",
          "to": "email_alert",
          "packet": "#/components/packets/AlertNotification",
          "when": "output.riskScore >= 0.9",
          "description": "Email the security team for critical events",
          "delivery": {
            "mode": "durable",
            "store": "mongo",
            "retryPolicy": { "$ref": "#/components/policies/alertRetry" }
          }
        }
      ]
    }
  },
  "components": {
    "policies": {
      "writeRetry": {
        "maxAttempts": 3,
        "initialDelayMs": 500,
        "backoff": "exponential",
        "maxDelayMs": 5000
      },
      "alertRetry": {
        "maxAttempts": 5,
        "initialDelayMs": 1000,
        "backoff": "exponential",
        "maxDelayMs": 30000,
        "deadLetterQueue": true
      }
    },
    "packets": {
      "IncomingEvent": {
        "type": "object",
        "description": "Raw event from the event bus",
        "properties": {
          "eventId": { "type": "string", "description": "Unique event identifier" },
          "eventType": { "type": "string", "description": "Event type/topic name" },
          "source": { "type": "string", "description": "Originating service" },
          "payload": { "type": "object", "description": "Event payload data" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["eventId", "eventType", "payload", "timestamp"]
      },
      "AnalysisResult": {
        "type": "object",
        "description": "LLM analysis output with risk score and classification",
        "properties": {
          "eventId": { "type": "string" },
          "summary": { "type": "string", "description": "LLM-generated summary of the event" },
          "category": { "type": "string", "description": "Classified category (e.g. security, performance, error)" },
          "riskScore": { "type": "number", "minimum": 0, "maximum": 1, "description": "Risk score from 0.0 (safe) to 1.0 (critical)" },
          "reasoning": { "type": "string", "description": "LLM's reasoning for the risk assessment" },
          "suggestedAction": { "type": "string", "description": "Recommended action to take" },
          "usage": {
            "type": "object",
            "properties": {
              "promptTokens": { "type": "number" },
              "completionTokens": { "type": "number" },
              "totalTokens": { "type": "number" }
            }
          },
          "analyzedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["eventId", "summary", "category", "riskScore", "analyzedAt"]
      },
      "AlertNotification": {
        "type": "object",
        "description": "Alert payload for high-risk events",
        "properties": {
          "eventId": { "type": "string" },
          "title": { "type": "string", "description": "Alert title" },
          "message": { "type": "string", "description": "Alert body with context" },
          "severity": { "type": "string", "enum": ["warning", "critical"] },
          "category": { "type": "string" },
          "riskScore": { "type": "number" },
          "suggestedAction": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "required": ["eventId", "title", "message", "severity", "timestamp"]
      }
    },
    "nodes": {
      "EventSourceNode": {
        "operationId": "redelay/event-source",
        "title": "Event Source",
        "summary": "Subscribe to events from the event bus",
        "kind": "source",
        "x-ui": {
          "icon": "Radio",
          "color": "#3B82F6",
          "position": { "x": 300, "y": 60 },
          "registryId": "redelay/event-source"
        }
      },
      "LLMAnalyzerNode": {
        "operationId": "analyze_event",
        "title": "LLM Analyzer",
        "summary": "Analyze event content with an LLM — classify risk and generate summary",
        "kind": "llm",
        "execution": {
          "timeoutMs": 30000,
          "concurrency": 10
        },
        "x-ui": {
          "icon": "Bot",
          "color": "#8B5CF6",
          "position": { "x": 300, "y": 220 },
          "registryId": "llm-analyzer"
        }
      },
      "ScoreRouterNode": {
        "operationId": "route_by_score",
        "title": "Score Router",
        "summary": "Fan out based on risk score — all to DB, high-risk to Slack, critical to email",
        "kind": "router",
        "x-ui": {
          "icon": "GitFork",
          "color": "#F59E0B",
          "position": { "x": 300, "y": 380 },
          "registryId": "filter-node"
        }
      },
      "MongoWriterNode": {
        "operationId": "persist_analysis",
        "title": "Mongo Writer",
        "summary": "Persist all analysis results to MongoDB for historical querying",
        "kind": "action",
        "idempotency": {
          "enabled": true,
          "keyExpression": "input.eventId",
          "ttlSeconds": 86400,
          "store": "redis"
        },
        "x-ui": {
          "icon": "DatabaseBackup",
          "color": "#F97316",
          "position": { "x": 120, "y": 540 },
          "registryId": "mongo-writer"
        }
      },
      "SlackNotifierNode": {
        "operationId": "notify_slack",
        "title": "Slack Alert",
        "summary": "Post high-risk event alerts to the ops Slack channel",
        "kind": "action",
        "x-ui": {
          "icon": "MessageSquare",
          "color": "#F97316",
          "position": { "x": 300, "y": 540 },
          "registryId": "slack-notifier"
        }
      },
      "EmailAlertNode": {
        "operationId": "email_security_team",
        "title": "Email Alert",
        "summary": "Send email to the security team for critical-risk events",
        "kind": "terminal",
        "x-ui": {
          "icon": "Mail",
          "color": "#EF4444",
          "position": { "x": 480, "y": 540 },
          "registryId": "email-sender"
        }
      }
    }
  }
}
